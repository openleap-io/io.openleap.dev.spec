{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sd.cdm.customer-master.updated",
  "title": "sd.cdm.customer-master.updated",
  "description": "Event published when a customer master record is updated in sd.cdm",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "sd.cdm.customer-master.updated" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "sd-cdm-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": ["customerId", "updatedFields"],
      "properties": {
        "customerId": { "type": "string", "format": "uuid" },
        "customerNumber": { "type": "string" },
        "updatedFields": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of field names that were changed in this update"
        },
        "creditLimit": { "type": "number" },
        "currency": { "type": "string" },
        "paymentTerms": { "type": "string" }
      }
    }
  }
}
