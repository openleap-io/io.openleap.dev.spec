{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pps.aps.capacity-schedule.optimized",
  "title": "pps.aps.capacity-schedule.optimized",
  "description": "Event published when an APS capacity schedule has been optimized",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "pps.aps.capacity-schedule.optimized" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "pps-aps-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": [],
      "properties": {
        "scheduleId": { "type": "string" },
        "plant": { "type": "string" },
        "periodStart": { "type": "string", "format": "date" },
        "periodEnd": { "type": "string", "format": "date" },
        "ordersRescheduled": { "type": "integer" },
        "overloadsResolved": { "type": "integer" }
      }
    }
  }
}
