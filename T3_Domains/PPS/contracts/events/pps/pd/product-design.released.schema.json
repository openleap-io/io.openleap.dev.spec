{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pps.pd.product-design.released",
  "title": "pps.pd.product-design.released",
  "description": "Event published when a product design (BOM/routing) has been released for production",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "pps.pd.product-design.released" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "pps-pd-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": [],
      "properties": {
        "designId": { "type": "string" },
        "material": { "type": "string" },
        "plant": { "type": "string" },
        "bomVersion": { "type": "string" },
        "routingVersion": { "type": "string" },
        "effectiveFrom": { "type": "string", "format": "date" },
        "releasedBy": { "type": "string" }
      }
    }
  }
}
