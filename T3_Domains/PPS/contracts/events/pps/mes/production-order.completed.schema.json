{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pps.mes.production-order.completed",
  "title": "pps.mes.production-order.completed",
  "description": "Event published when a production order has been completed on the shop floor",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "pps.mes.production-order.completed" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "pps-mes-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": [],
      "properties": {
        "productionOrderId": { "type": "string" },
        "material": { "type": "string" },
        "plant": { "type": "string" },
        "orderedQty": { "type": "number" },
        "deliveredQty": { "type": "number" },
        "scrapQty": { "type": "number" },
        "unit": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
