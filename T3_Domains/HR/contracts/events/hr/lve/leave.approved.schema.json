{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openleap.io/hr/lve/leave.approved",
  "title": "LeaveApproved",
  "description": "Emitted when a leave request is approved.",
  "type": "object",
  "required": ["eventId", "occurredAt", "tenantId", "leaveRequestId", "employeeId", "startDate", "endDate", "days"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "leaveRequestId": { "type": "string", "format": "uuid" },
    "employeeId": { "type": "string", "format": "uuid" },
    "leaveTypeCode": { "type": "string" },
    "startDate": { "type": "string", "format": "date" },
    "endDate": { "type": "string", "format": "date" },
    "days": { "type": "number", "minimum": 0.5 },
    "approvedBy": { "type": "string", "format": "uuid" }
  }
}
