{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openleap.io/schemas/events/crm.act.call.logged.schema.json",
  "title": "CallLogged",
  "description": "Event schema for crm.act.call.logged",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "timestamp",
    "tenantId",
    "correlationId",
    "producer",
    "schemaVersion",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "crm.act.call.logged"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "tenantId": {
      "type": "string",
      "format": "uuid"
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "causationId": {
      "type": "string",
      "format": "uuid"
    },
    "producer": {
      "type": "string",
      "const": "crm-act-svc"
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "userId": {
      "type": "string",
      "format": "uuid"
    },
    "payload": {
      "type": "object",
      "required": [
        "callId",
        "direction",
        "duration",
        "outcome",
        "contactId"
      ],
      "properties": {
        "callId": {
          "type": "string",
          "format": "uuid"
        },
        "direction": {
          "type": "string"
        },
        "duration": {
          "type": "integer"
        },
        "outcome": {
          "type": "string"
        },
        "contactId": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "traceId": {
          "type": "string"
        },
        "spanId": {
          "type": "string"
        }
      }
    }
  }
}