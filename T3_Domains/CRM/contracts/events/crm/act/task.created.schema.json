{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openleap.io/schemas/events/crm.act.task.created.schema.json",
  "title": "TaskCreated",
  "description": "Event schema for crm.act.task.created",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "timestamp",
    "tenantId",
    "correlationId",
    "producer",
    "schemaVersion",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "crm.act.task.created"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "tenantId": {
      "type": "string",
      "format": "uuid"
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "causationId": {
      "type": "string",
      "format": "uuid"
    },
    "producer": {
      "type": "string",
      "const": "crm-act-svc"
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "userId": {
      "type": "string",
      "format": "uuid"
    },
    "payload": {
      "type": "object",
      "required": [
        "taskId",
        "subject",
        "dueDate",
        "assigneeId",
        "relatedToType",
        "relatedToId"
      ],
      "properties": {
        "taskId": {
          "type": "string",
          "format": "uuid"
        },
        "subject": {
          "type": "string"
        },
        "dueDate": {
          "type": "string"
        },
        "assigneeId": {
          "type": "string",
          "format": "uuid"
        },
        "relatedToType": {
          "type": "string"
        },
        "relatedToId": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "traceId": {
          "type": "string"
        },
        "spanId": {
          "type": "string"
        }
      }
