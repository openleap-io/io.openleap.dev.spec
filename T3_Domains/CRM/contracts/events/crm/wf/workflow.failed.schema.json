{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openleap.io/schemas/events/crm.wf.workflow.failed.schema.json",
  "title": "WorkflowFailed",
  "description": "Event schema for crm.wf.workflow.failed",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "timestamp",
    "tenantId",
    "correlationId",
    "producer",
    "schemaVersion",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "crm.wf.workflow.failed"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "tenantId": {
      "type": "string",
      "format": "uuid"
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "causationId": {
      "type": "string",
      "format": "uuid"
    },
    "producer": {
      "type": "string",
      "const": "crm-wf-svc"
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "userId": {
      "type": "string",
      "format": "uuid"
    },
    "payload": {
      "type": "object",
      "required": [
        "executionId",
        "workflowId",
        "failedAction",
        "error"
      ],
      "properties": {
        "executionId": {
          "type": "string",
          "format": "uuid"
        },
        "workflowId": {
          "type": "string",
          "format": "uuid"
        },
        "failedAction": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "traceId": {
          "type": "string"
        },
        "spanId": {
          "type": "string"
        }
      }
    }
  }
}