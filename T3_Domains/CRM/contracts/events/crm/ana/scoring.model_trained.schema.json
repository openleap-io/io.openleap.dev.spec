{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openleap.io/schemas/events/crm.ana.scoring.model_trained.schema.json",
  "title": "ScoringModelTrained",
  "description": "Event schema for crm.ana.scoring.model_trained",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "timestamp",
    "tenantId",
    "correlationId",
    "producer",
    "schemaVersion",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "crm.ana.scoring.model_trained"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "tenantId": {
      "type": "string",
      "format": "uuid"
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "causationId": {
      "type": "string",
      "format": "uuid"
    },
    "producer": {
      "type": "string",
      "const": "crm-ana-svc"
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "userId": {
      "type": "string",
      "format": "uuid"
    },
    "payload": {
      "type": "object",
      "required": [
        "modelId",
        "accuracy",
        "trainingSize"
      ],
      "properties": {
        "modelId": {
          "type": "string",
          "format": "uuid"
        },
        "accuracy": {
          "type": "number"
        },
        "trainingSize": {
          "type": "integer"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "traceId": {
          "type": "string"
        },
        "spanId": {
          "type": "string"
        }
      }
    }
  }
}