{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openleap.io/schemas/events/crm.prod.product.created.schema.json",
  "title": "ProductCreated",
  "description": "Event schema for crm.prod.product.created",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "timestamp",
    "tenantId",
    "correlationId",
    "producer",
    "schemaVersion",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "crm.prod.product.created"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "tenantId": {
      "type": "string",
      "format": "uuid"
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "causationId": {
      "type": "string",
      "format": "uuid"
    },
    "producer": {
      "type": "string",
      "const": "crm-prod-svc"
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "userId": {
      "type": "string",
      "format": "uuid"
    },
    "payload": {
      "type": "object",
      "required": [
        "productId",
        "name",
        "code",
        "type",
        "listPrice"
      ],
      "properties": {
        "productId": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "listPrice": {
          "type": "number"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "traceId": {
          "type": "string"
        },
        "spanId": {
          "type": "string"
        }
      }
    }
  }
}