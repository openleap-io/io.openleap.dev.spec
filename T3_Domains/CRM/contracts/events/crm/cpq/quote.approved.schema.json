{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openleap.io/schemas/events/crm.cpq.quote.approved.schema.json",
  "title": "QuoteApproved",
  "description": "Event schema for crm.cpq.quote.approved",
  "type": "object",
  "required": [
    "eventId",
    "eventType",
    "timestamp",
    "tenantId",
    "correlationId",
    "producer",
    "schemaVersion",
    "payload"
  ],
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid"
    },
    "eventType": {
      "type": "string",
      "const": "crm.cpq.quote.approved"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "tenantId": {
      "type": "string",
      "format": "uuid"
    },
    "correlationId": {
      "type": "string",
      "format": "uuid"
    },
    "causationId": {
      "type": "string",
      "format": "uuid"
    },
    "producer": {
      "type": "string",
      "const": "crm-cpq-svc"
    },
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "userId": {
      "type": "string",
      "format": "uuid"
    },
    "payload": {
      "type": "object",
      "required": [
        "quoteId",
        "approvedBy"
      ],
      "properties": {
        "quoteId": {
          "type": "string",
          "format": "uuid"
        },
        "approvedBy": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "traceId": {
          "type": "string"
        },
        "spanId": {
          "type": "string"
        }
      }
