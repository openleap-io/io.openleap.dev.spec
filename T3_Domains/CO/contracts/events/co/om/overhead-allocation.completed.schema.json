{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "co.om.overhead-allocation.completed",
  "title": "co.om.overhead-allocation.completed",
  "description": "Event published when an overhead allocation cycle has completed successfully",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "co.om.overhead-allocation.completed" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "co-om-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": [],
      "properties": {
        "cycleId": { "type": "string" },
        "period": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
        "cycleType": { "type": "string", "enum": ["ACTUAL", "PLAN"] },
        "postingCount": { "type": "integer" },
        "totalDebited": { "type": "number" },
        "currency": { "type": "string", "maxLength": 3 },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
