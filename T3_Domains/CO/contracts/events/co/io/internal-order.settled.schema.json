{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "co.io.internal-order.settled",
  "title": "co.io.internal-order.settled",
  "description": "Event published when an internal order has been fully settled to its settlement receivers",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "co.io.internal-order.settled" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "co-io-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": [],
      "properties": {
        "orderId": { "type": "string" },
        "orderType": { "type": "string" },
        "period": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
        "settlementAmount": { "type": "number" },
        "currency": { "type": "string", "maxLength": 3 },
        "settlementRule": { "type": "string" },
        "receiverType": { "type": "string", "enum": ["COST_CENTER", "PROFIT_CENTER", "GL_ACCOUNT", "ASSET"] }
      }
    }
  }
}
