{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "co.pa.profitability-segment.updated",
  "title": "co.pa.profitability-segment.updated",
  "description": "Event published when a profitability segment has been recalculated or updated",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "co.pa.profitability-segment.updated" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "co-pa-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": [],
      "properties": {
        "segmentId": { "type": "string" },
        "segmentType": { "type": "string", "enum": ["COMPANY", "DIVISION", "CUSTOMER", "PRODUCT"] },
        "period": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
        "revenue": { "type": "number" },
        "cogs": { "type": "number" },
        "contributionMargin": { "type": "number" },
        "currency": { "type": "string", "maxLength": 3 },
        "isPreliminary": { "type": "boolean" }
      }
    }
  }
}
