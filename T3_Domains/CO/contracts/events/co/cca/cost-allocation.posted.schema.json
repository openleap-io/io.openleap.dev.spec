{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "co.cca.cost-allocation.posted",
  "title": "co.cca.cost-allocation.posted",
  "description": "Event published when a cost allocation posting has been recorded in cost center accounting",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "co.cca.cost-allocation.posted" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "co-cca-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": [],
      "properties": {
        "postingId": { "type": "string", "format": "uuid" },
        "senderCostCenter": { "type": "string" },
        "receiverCostCenter": { "type": "string" },
        "costElement": { "type": "string" },
        "period": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
        "amount": { "type": "number" },
        "currency": { "type": "string", "maxLength": 3 },
        "controllingArea": { "type": "string" }
      }
    }
  }
}
