{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "co.rpt.management-report.generated",
  "title": "co.rpt.management-report.generated",
  "description": "Event published when a management report has been generated and is available for distribution",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "co.rpt.management-report.generated" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "co-rpt-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": [],
      "properties": {
        "reportId": { "type": "string" },
        "reportType": { "type": "string", "enum": ["COST_CENTER", "PROFIT_CENTER", "PROFITABILITY", "VARIANCE"] },
        "period": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
        "generatedBy": { "type": "string" },
        "generatedAt": { "type": "string", "format": "date-time" },
        "recipientCount": { "type": "integer" },
        "storageReference": { "type": "string" }
      }
    }
  }
}
