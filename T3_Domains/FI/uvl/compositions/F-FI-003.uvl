        mandatory
            F_FI_003_01 { description "AP Invoice Management" }
            F_FI_003_02 { description "Payment Execution" }
        optional
            F_FI_003_03 { description "Procurement Matching (3-Way)" }
            F_FI_003_04 { description "Payment Run Scheduling" }

constraints
