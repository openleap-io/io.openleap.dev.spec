{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openleap.io/fi/gl/journal-entry.posted",
  "title": "JournalEntryPosted",
  "description": "Emitted when a journal entry is posted to the general ledger.",
  "type": "object",
  "required": ["eventId", "occurredAt", "tenantId", "journalEntryId"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "journalEntryId": { "type": "string", "format": "uuid" }
  }
}
