{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openleap.io/fi/fa/asset.capitalized",
  "title": "AssetCapitalized",
  "description": "Emitted when a fixed asset is capitalized and activated in the asset register.",
  "type": "object",
  "required": ["eventId", "occurredAt", "tenantId", "assetId"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "occurredAt": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "assetId": { "type": "string", "format": "uuid" }
  }
}
