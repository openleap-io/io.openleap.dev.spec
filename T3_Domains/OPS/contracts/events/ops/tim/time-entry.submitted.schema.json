{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ops.tim.time-entry.submitted",
  "title": "ops.tim.time-entry.submitted",
  "description": "Event published when a time entry is submitted for manager approval",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "ops.tim.time-entry.submitted" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "ops-tim-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": ["timeEntryId", "resourceId", "hours", "billable", "submittedAt"],
      "properties": {
        "timeEntryId": { "type": "string", "format": "uuid" },
        "resourceId": { "type": "string", "format": "uuid" },
        "costObjectId": { "type": "string", "format": "uuid" },
        "costObjectType": { "type": "string", "enum": ["WORK_ORDER", "PROJECT", "TASK"] },
        "hours": { "type": "number", "minimum": 0.25, "maximum": 24 },
        "billable": { "type": "boolean" },
        "serviceDate": { "type": "string", "format": "date" },
        "submittedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
