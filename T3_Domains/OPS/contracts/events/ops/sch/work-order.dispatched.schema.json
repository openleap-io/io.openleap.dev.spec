{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ops.sch.work-order.dispatched",
  "title": "ops.sch.work-order.dispatched",
  "description": "Event published when a work order is dispatched to an assigned resource",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "ops.sch.work-order.dispatched" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "ops-sch-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": ["assignmentId", "workOrderId", "resourceId", "scheduledFrom", "scheduledTo"],
      "properties": {
        "assignmentId": { "type": "string", "format": "uuid" },
        "workOrderId": { "type": "string", "format": "uuid" },
        "resourceId": { "type": "string", "format": "uuid" },
        "dispatchedBy": { "type": "string", "format": "uuid" },
        "scheduledFrom": { "type": "string", "format": "date-time" },
        "scheduledTo": { "type": "string", "format": "date-time" },
        "notificationSent": { "type": "boolean" }
      }
    }
  }
}
