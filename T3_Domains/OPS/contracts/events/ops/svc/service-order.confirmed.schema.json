{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ops.svc.service-order.confirmed",
  "title": "ops.svc.service-order.confirmed",
  "description": "Event published when a service delivery is confirmed and a billable item is generated",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "ops.svc.service-order.confirmed" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "ops-svc-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": ["deliveryId", "workOrderId", "billableItemId", "amount", "currency"],
      "properties": {
        "deliveryId": { "type": "string", "format": "uuid" },
        "workOrderId": { "type": "string", "format": "uuid" },
        "billableItemId": { "type": "string", "format": "uuid" },
        "amount": { "type": "number" },
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "deliveryType": { "type": "string", "enum": ["TIME_BASED", "QUANTITY_BASED", "MILESTONE_BASED"] },
        "confirmedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
