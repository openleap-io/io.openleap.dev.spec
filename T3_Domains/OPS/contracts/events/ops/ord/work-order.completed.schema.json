{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ops.ord.work-order.completed",
  "title": "ops.ord.work-order.completed",
  "description": "Event published when a work order is completed and closed",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "ops.ord.work-order.completed" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "ops-ord-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": ["workOrderId", "completionCode", "completedAt"],
      "properties": {
        "workOrderId": { "type": "string", "format": "uuid" },
        "customerId": { "type": "string", "format": "uuid" },
        "sourceOrderId": { "type": "string", "format": "uuid", "description": "COM sales order reference" },
        "completionCode": { "type": "string", "enum": ["RESOLVED", "CANCELLED", "DEFERRED", "ESCALATED"] },
        "completedAt": { "type": "string", "format": "date-time" },
        "assignedResourceId": { "type": "string", "format": "uuid" }
      }
    }
  }
}
