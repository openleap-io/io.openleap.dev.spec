{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ops.tsk.task.completed",
  "title": "ops.tsk.task.completed",
  "description": "Event published when a project task status changes to DONE",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "ops.tsk.task.completed" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "ops-tsk-svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": ["taskId", "projectId", "milestoneId", "completedAt"],
      "properties": {
        "taskId": { "type": "string", "format": "uuid" },
        "projectId": { "type": "string", "format": "uuid" },
        "milestoneId": { "type": "string", "format": "uuid" },
        "taskTitle": { "type": "string" },
        "assigneeId": { "type": "string", "format": "uuid" },
        "loggedHours": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
