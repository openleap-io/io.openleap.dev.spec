{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "param.cfg.config.changed",
  "title": "param.cfg.config.changed",
  "description": "Event published when config is changed",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "param.cfg.config.changed" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "param--svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": [],
      "properties": {
        "scope": { "type": "string", "enum": ["GLOBAL", "TENANT"] },
        "tenantId": { "type": "string", "format": "uuid" },
        "key": { "type": "string" },
        "configType": { "type": "string" },
        "previousValue": { "type": "string" },
        "newValue": { "type": "string" }
      }
    }
  }
}
