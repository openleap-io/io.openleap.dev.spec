{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "param.i18n.namespace.seeded",
  "title": "param.i18n.namespace.seeded",
  "description": "Event published when namespace is seeded",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "param.i18n.namespace.seeded" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "param--svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": [],
      "properties": {
        "namespace": { "type": "string" },
        "keyCount": { "type": "integer" },
        "locales": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
