{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "param.si.unit.deleted",
  "title": "param.si.unit.deleted",
  "description": "Event published when unit is deleted",
  "type": "object",
  "required": ["eventId", "eventType", "timestamp", "tenantId", "correlationId", "producer", "schemaVersion", "payload"],
  "properties": {
    "eventId": { "type": "string", "format": "uuid" },
    "eventType": { "type": "string", "const": "param.si.unit.deleted" },
    "timestamp": { "type": "string", "format": "date-time" },
    "tenantId": { "type": "string", "format": "uuid" },
    "correlationId": { "type": "string", "format": "uuid" },
    "causationId": { "type": "string", "format": "uuid" },
    "producer": { "type": "string", "const": "param--svc" },
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "payload": {
      "type": "object",
      "required": [],
      "properties": {
        "unitId": { "type": "string", "format": "uuid" },
        "symbol": { "type": "string" }
      }
    }
  }
}
