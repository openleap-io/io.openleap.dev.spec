    // F-AUTO-WF-001  as WorkflowBuilder
    // F-AUTO-WF-002  as WorkflowTemplateLibrary
    // F-AUTO-WF-003  as WorkflowMonitorAndLogs
    // F-AUTO-WF-004  as AssignmentAndEscalationRules

features

    // Suite root — the top-level feature representing the auto
    // suite's entire UI capability.
    // This is the node that the platform catalog.uvl references.
    Auto_UI

        optional
